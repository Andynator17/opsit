# =====================================================================
# OpsIT - Environment configuration
# Copy this file to `.env` on the VPS and fill in real values.
# NEVER commit the real .env to git.
#
# Stack assumptions:
#   - Existing Traefik (`traefik-nhwc`, network_mode: host) handles
#     ports 80/443 + Let's Encrypt via the `letsencrypt` certresolver
#     and the `websecure` entrypoint.
#   - Existing n8n (`n8n-irio`) routed via Traefik on n8n.hitex.at.
#   - OpsIT brings its own dedicated Postgres (does NOT use the
#     existing `postgresql-cjc4`).
#   - Single subdomain layout (Variant A): everything under
#     opsit-dev.hitex.at, /api/* goes to backend, rest to frontend.
# =====================================================================

# ---- Domain ----
DOMAIN_OPSIT=opsit-dev.hitex.at

# ---- PostgreSQL (OpsIT-only, internal only) ----
POSTGRES_USER=opsit
POSTGRES_PASSWORD=change-me-strong-password
POSTGRES_DB=opsit

# ---- OpsIT backend ----
# async driver for SQLAlchemy + asyncpg; host = compose service name
DATABASE_URL=postgresql+asyncpg://opsit:change-me-strong-password@postgres:5432/opsit
SECRET_KEY=change-me-generate-with-openssl-rand-hex-32
DEBUG=false
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7
# CORS is empty in Variant A (frontend and API on the same origin).
# Only fill this if you ever call the API from another origin.
BACKEND_CORS_ORIGINS=
FIRST_ADMIN_EMAIL=admin@hitex.at
FIRST_ADMIN_PASSWORD=change-me-on-first-login

# ---- Frontend build-time ----
# Relative URL so the SPA calls its own origin. Change ONLY if you move
# to a separate API subdomain (Variant B). Build-time only — changing
# this requires `docker compose build frontend && up -d frontend`.
VITE_API_URL=/api/v1
