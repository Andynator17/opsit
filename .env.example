# =====================================================================
# OpsIT - Environment configuration
# Copy this file to `.env` on the VPS and fill in real values.
# NEVER commit the real .env to git.
#
# This stack assumes an EXISTING Traefik (container `traefik-nhwc`) and
# n8n (`n8n-irio`) already run on the host. OpsIT joins the existing
# Traefik docker network so Traefik can route to it.
# =====================================================================

# ---- Domains (used by Traefik routers + CORS + frontend bundle) ----
DOMAIN_APP=app.example.com
DOMAIN_API=api.example.com
DOMAIN_LANDING=example.com

# ---- Traefik integration (override only if your Traefik uses other names) ----
# The Docker network that traefik-nhwc is attached to:
TRAEFIK_NETWORK=traefik
# The HTTPS entrypoint name in your traefik static config:
TRAEFIK_ENTRYPOINT=websecure
# The certresolver name in your traefik static config:
TRAEFIK_CERTRESOLVER=letsencrypt

# ---- PostgreSQL (OpsIT's own instance, internal only) ----
POSTGRES_USER=opsit
POSTGRES_PASSWORD=change-me-strong-password
POSTGRES_DB=opsit

# ---- OpsIT backend ----
# async driver for SQLAlchemy + asyncpg; host = compose service name
DATABASE_URL=postgresql+asyncpg://opsit:change-me-strong-password@postgres:5432/opsit
SECRET_KEY=change-me-generate-with-openssl-rand-hex-32
DEBUG=false
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7
BACKEND_CORS_ORIGINS=https://app.example.com,https://example.com
FIRST_ADMIN_EMAIL=admin@example.com
FIRST_ADMIN_PASSWORD=change-me-on-first-login

# ---- Frontend build-time ----
# baked into the Vite bundle at build time — change requires `docker compose build frontend`
VITE_API_BASE_URL=https://api.example.com
