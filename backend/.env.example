# Application
PROJECT_NAME=OpsIT
VERSION=1.0.0
API_V1_PREFIX=/api/v1
DEBUG=True

# Database
DATABASE_URL=postgresql+asyncpg://opsit:opsit_dev_password@localhost:5432/opsit_dev

# Security
SECRET_KEY=change-this-to-a-random-secret-key-min-32-characters-long
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# CORS
BACKEND_CORS_ORIGINS=["http://localhost:3000","http://localhost:5173"]

# First Admin User (for seeding)
FIRST_ADMIN_EMAIL=admin@opsit.local
FIRST_ADMIN_PASSWORD=Admin123!
